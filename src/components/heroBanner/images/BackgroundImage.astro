---
import { CldImage } from 'astro-cloudinary'

import { colors } from '../../../lib/styles'

interface Props {
    image?: string
}

const { image } = Astro.props
---

<style define:vars={{ colorsEvening70: colors.evening70 }}>
    div {
        display: none;
    }

    @media (min-width: 1200px) {
        div {
            display: flex;
            height: 100%;
            overflow: hidden;
            position: absolute;
            width: 100%;
        }

        div:after {
            background-image: linear-gradient(var(--colorsEvening70), var(--colorsEvening70));
            bottom: 0;
            content: '';
            height: 100%;
            position: absolute;
            top: 0;
            width: 100%;
        }
    }
</style>
<>
    {
        image && (
            <div>
                <CldImage
                    alt=""
                    crop={{ source: true, type: 'fill' }}
                    fetchpriority="high"
                    height={660}
                    layout="fullWidth"
                    src={image}
                    width={1920}
                />
            </div>
        )
    }
</>
