---
import { colors, sizes, typographics } from '../../lib/styles'
import NameLogo from '../NameLogo.astro'

interface Props {
    title: string
    subtitle?: string
    secondaryTitle?: string
}

const { subtitle, secondaryTitle } = Astro.props
---

<style
    define:vars={{
        colorsWhite: colors.white,
        h2FontFamily: typographics.h2.fontFamily,
        h2FontSize: typographics.h2.fontSize,
        h2FontWeight: typographics.h2.fontWeight,
        h2LineHeight: typographics.h2.lineHeight,
        ingressFontFamily: typographics.ingress.fontFamily,
        ingressFontSize: typographics.ingress.fontSize,
        ingressFontWeight: typographics.ingress.fontWeight,
        ingressLineHeight: typographics.ingress.lineHeight,
        sizes0875: sizes[0.875],
        sizes3: sizes[3],
        sizes15: sizes[1.5],
        sizes375: sizes[3.75],
    }}
>
    div {
        color: var(--colorsWhite);
        display: flex;
        flex-direction: column;
        gap: var(--sizes15);
        margin-top: var(--sizes3);
        padding: var(--sizes0875);
    }

    h2 {
        font-family: var(--h2FontFamily);
        font-weight: var(--h2FontWeight);
        font-size: var(--h2FontSize);
        line-height: var(--h2LineHeight);
    }

    p {
        font-family: var(--ingressFontFamily);
        font-weight: var(--ingressFontWeight);
        font-size: var(--ingressFontSize);
        line-height: var(--ingressLineHeight);
    }

    @media (min-width: 1200px) {
        div {
            align-items: flex-start;
            gap: var(--sizes3);
            justify-content: flex-start;
            padding: var(--sizes375);
            width: 50%;
        }
    }
</style>
<div>
    <h1><NameLogo /></h1>
    {subtitle && <p>{subtitle}</p>}
    {secondaryTitle && <h2>{secondaryTitle}</h2>}
</div>
