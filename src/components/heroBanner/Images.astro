---
/* eslint-disable astro/no-unused-css-selector */
import type { ImageMetadata } from 'astro'

import { Image, Source } from '@unpic/astro' /* eslint-disable-line import/no-unresolved */

import { sizes } from '../../lib/styles'
import BackgroundImage from './images/BackgroundImage.astro'

interface Props {
    alt?: string
    backgroundImage?: string
    croppedHeroImage?: string
    heroImage?: string
}

const { alt, backgroundImage, croppedHeroImage, heroImage } = Astro.props

const allLocalImages = import.meta.glob<ImageMetadata>('../../images/*.{jpg,png}', { eager: true, import: 'default' })
const resolvedHero = heroImage ? allLocalImages[`../../images/${heroImage}`] : null
const resolvedCropped = croppedHeroImage ? allLocalImages[`../../images/${croppedHeroImage}`] : null
---

<style define:vars={{ sizes1Negative: `-${sizes[1]}`, sizes2: sizes[2], sizes5Negative: `-${sizes[5]}` }}>
    .container {
        display: flex;
        flex: 1;
        overflow: hidden;
        position: relative;
        margin-top: var(--sizes2);
    }

    .image {
        margin-left: var(--sizes1Negative);
    }

    @media (min-width: 1200px) {
        .container {
            overflow: visible;
            width: 50%;
            margin-top: 0;
        }

        .image {
            bottom: 0;
            position: absolute;
            right: var(--sizes5Negative);
            margin-top: auto;
        }
    }
</style>
<div class="container">
    <BackgroundImage image={backgroundImage} />
    {
        resolvedHero && resolvedCropped && (
            <picture>
                <Source height={562} src={resolvedCropped} type="image/avif" width={560} />
                <Source height={562} src={resolvedCropped} type="image/webp" width={560} />
                <Image
                    alt={alt ?? ''}
                    background="transparent"
                    class="image"
                    height={562}
                    layout="constrained"
                    priority
                    src={resolvedHero}
                    width={560}
                />
            </picture>
        )
    }
</div>
