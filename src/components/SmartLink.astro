---
import ExternalLink from './ExternalLink.astro'
import Link from './Link.astro'

interface Props {
    ariaLabel?: string
    heading?: boolean
    href: string
    rel?: string
}

const { ariaLabel, heading, href, rel } = Astro.props

const isInternal = href.startsWith('/')
---

{
    isInternal ? (
        <Link heading={heading} href={href} rel={rel}>
            <slot />
        </Link>
    ) : (
        <ExternalLink ariaLabel={ariaLabel} href={href} rel={rel}>
            <slot />
        </ExternalLink>
    )
}
