---
import LI from '../../LI.astro'

interface Props {
    duty?: string
    title?: string
    degree?: string
    description?: string[]
    organization?: string
    company?: string
    school?: string
    location?: string
    startYear: number
    endYear?: number
}

const { duty, title, degree, description, organization, company, school, location, startYear, endYear } = Astro.props

const years = startYear === endYear ? `${startYear}` : `${startYear}–${endYear ?? ''}`
---

<LI heavy={!endYear}>
    <span>
        {duty || title || degree || ''}
    </span>
    <i>
        {organization || company || school || ''}{location ? ` (${location}) ` : ' '}
        {years}
    </i>
    {description && (
        <ul>
            {description.map((item) => <li>{item}</li>)}
        </ul>
    )}
</LI>
