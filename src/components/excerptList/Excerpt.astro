---
import type { TagCollection } from '../../types/local'

import { sizes } from '../../lib/styles'
import Meta from '../Meta.astro'
import Banner from './excerpt/Banner.astro'
import Description from './excerpt/Description.astro'

interface Props {
    allTags: TagCollection
    alt?: string
    date?: string
    excerpt?: string
    image?: string
    lang?: 'en' | 'fi' | 'sv'
    slug?: string
    tags?: string[]
    title: string
}

const { allTags, alt, date, excerpt, image, lang = 'fi', slug, tags, title } = Astro.props

const metaAriaLabels = {
    en: (t: string) => `Meta information for post "${t}"`,
    fi: (t: string) => `Kirjoituksen "${t}" meta-tiedot`,
    sv: (t: string) => `Metainformation för inlägget "${t}"`,
}
---

<style define:vars={{ sizes35: sizes[35] }}>
    li {
        max-width: var(--sizes35);
    }
</style>
<li>
    <article aria-label={title} itemscope itemtype="https://schema.org/CreativeWork">
        <Banner alt={alt} image={image} slug={slug} title={title} />
        {
            date && tags && (
                <Meta allTags={allTags} ariaLabel={metaAriaLabels[lang](title)} date={date} lang={lang} tags={tags} />
            )
        }
        <Description excerpt={excerpt} />
    </article>
</li>
