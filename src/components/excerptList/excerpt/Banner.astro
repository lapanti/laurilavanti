---
/* eslint-disable astro/no-unused-css-selector */
import type { ImageMetadata } from 'astro'

import { Image, Source } from '@unpic/astro' /* eslint-disable-line import/no-unresolved */

import { sizes } from '../../../lib/styles'
import H2 from '../../H2.astro'

interface Props {
    localAlt?: string
    localImage?: string
    slug?: string
    title: string
}

const { localAlt, localImage, slug, title } = Astro.props

const allLocalImages = import.meta.glob<ImageMetadata>('../../../images/**/*.{jpg,JPG,jpeg,png}', {
    eager: true,
    import: 'default',
})
const resolvedLocal = localImage ? allLocalImages[`../../../images/${localImage}`] : null
---

<style define:vars={{ sizes025: sizes[0.25], sizes01875: sizes[0.1875] }}>
    a {
        color: black;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
        text-decoration-thickness: var(--sizes01875);
    }

    .excerpt-image {
        max-height: 315px;
        max-width: 560px;
        height: 100%;
        width: 100%;
    }

    a div {
        align-items: flex-end;
        display: flex;
        margin-top: var(--sizes025);
        position: relative;
        width: 100%;
    }

    h2 {
        grid-column-start: auto;
    }
</style>
<a href={`/${slug}/`} rel="permalink">
    {
        resolvedLocal && (
            <picture>
                <Source layout="constrained" src={resolvedLocal} type="image/avif" />
                <Source layout="constrained" src={resolvedLocal} type="image/webp" />
                <Image
                    alt={localAlt ?? ''}
                    class="excerpt-image"
                    height={315}
                    layout="constrained"
                    src={resolvedLocal}
                    width={560}
                />
            </picture>
        )
    }
    <div>
        <H2 itemProp="headline">{title}</H2>
    </div>
</a>
