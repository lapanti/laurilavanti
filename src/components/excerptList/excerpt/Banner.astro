---
/* eslint-disable astro/no-unused-css-selector */
import { getImageSrcset } from '../../../lib/images'
import { sizes } from '../../../lib/styles'
import H2 from '../../H2.astro'

interface Props {
    alt?: string
    image?: string
    slug?: string
    title: string
}

const { alt, image, slug, title } = Astro.props
const img = image ? getImageSrcset(image, '1x1', [560, 1120]) : undefined
---

<style define:vars={{ sizes025: sizes[0.25], sizes01875: sizes[0.1875] }}>
    a {
        color: black;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
        text-decoration-thickness: var(--sizes01875);
    }

    .excerpt-image {
        aspect-ratio: 1;
        height: auto;
        object-fit: cover;
        width: 100%;
    }

    a div {
        align-items: flex-end;
        display: flex;
        margin-top: var(--sizes025);
        position: relative;
        width: 100%;
    }

    h2 {
        grid-column-start: auto;
    }
</style>
<a href={`/${slug}/`} rel="permalink">
    {
        img && (
            <img
                alt={alt ?? ''}
                class="excerpt-image"
                height={img.height}
                sizes="(max-width: 1199px) 100vw, 33vw"
                src={img.src}
                srcset={img.srcset}
                width={img.width}
            />
        )
    }
    <div>
        <H2 itemProp="headline">{title}</H2>
    </div>
</a>
