---
/* eslint-disable astro/no-unused-css-selector */
import { sizes } from '../../../lib/styles'
import Paragraph from '../../Paragraph.astro'

interface Props {
    excerpt?: string
}

const { excerpt } = Astro.props
---

<style define:vars={{ sizes025: sizes[0.25] }}>
    p {
        margin-top: var(--sizes025);
    }
</style>
<Paragraph inGrid={false} itemProp="description">
    {excerpt}
</Paragraph>
