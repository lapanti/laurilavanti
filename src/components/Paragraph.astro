---
/* eslint-disable astro/no-unused-css-selector */
import { sizes } from '../lib/styles'

interface Props {
    inGrid?: boolean
    itemProp?: string
    noMargins?: boolean
    smallMarginTop?: boolean
}

const { inGrid = true, itemProp, smallMarginTop, noMargins } = Astro.props
---

<style
    define:vars={{
        marginBottom: noMargins ? 0 : sizes[1],
        marginTop: noMargins ? 0 : smallMarginTop ? sizes[0.25] : sizes[1],
    }}
>
    p {
        margin-bottom: var(--marginBottom);
        margin-top: var(--marginTop);
    }

    li > p {
        margin-bottom: 0;
        margin-top: 0;
    }
</style>
<p itemprop={itemProp} style={{ ...(inGrid ? { gridColumnStart: 3 } : {}) }}>
    <slot />
</p>
