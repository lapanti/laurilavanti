---
import type { AuthorEntry } from '../content/person'
import type { ExternalPublication } from '../lib/byline'

import { buildBylineText, formatPublicationDate } from '../lib/byline'

interface Props {
    authors: AuthorEntry[]
    externalPublications?: ExternalPublication[]
    lang: 'en' | 'fi' | 'sv'
}

const { authors, externalPublications, lang } = Astro.props
const text = buildBylineText(authors, lang)

const publicationPrefix: Record<string, string> = {
    en: 'Also published in',
    fi: 'Julkaistu myös',
    sv: 'Publicerat även i',
}
---

<style>
    p {
        grid-column-start: 3;
        margin-block: 0;
    }
</style>
{
    text && (
        <p>
            <em>{text}</em>
        </p>
    )
}
{
    externalPublications?.map((pub: ExternalPublication) => (
        <p>
            <em>
                {publicationPrefix[lang]}: {pub.url ? <a href={pub.url}>{pub.name}</a> : pub.name},{' '}
                {formatPublicationDate(pub.date, lang)}.
            </em>
        </p>
    ))
}
