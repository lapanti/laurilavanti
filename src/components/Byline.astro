---
import type { AuthorEntry } from '../content/person'
import type { ExternalPublication } from '../lib/byline'

import { buildBylineText, formatPublicationDate } from '../lib/byline'

interface Props {
    authors: AuthorEntry[]
    externalPublication?: ExternalPublication
    lang: 'en' | 'fi' | 'sv'
}

const { authors, externalPublication, lang } = Astro.props
const text = buildBylineText(authors, lang)

const publicationPrefix: Record<string, string> = {
    en: 'Also published in',
    fi: 'Julkaistu myös',
    sv: 'Publicerat även i',
}
---

<style>
    p {
        grid-column-start: 3;
        margin-block: 0;
    }
</style>
{
    text && (
        <p>
            <em>{text}</em>
        </p>
    )
}
{
    externalPublication && (
        <p>
            <em>
                {publicationPrefix[lang]}:{' '}
                {externalPublication.url ? (
                    <a href={externalPublication.url}>{externalPublication.name}</a>
                ) : (
                    externalPublication.name
                )}
                , {formatPublicationDate(externalPublication.date, lang)}.
            </em>
        </p>
    )
}
