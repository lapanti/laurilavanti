---
import type { Lang } from '../../content/nav'

import { skipLinks } from '../../content/nav'
import { colors, sizes, zIndices } from '../../lib/styles'

interface Props {
    lang?: Lang
}

const { lang = 'fi' } = Astro.props
const labels = skipLinks[lang]
---

<style define:vars={{ colorsWhite: colors.white, rem05: sizes[0.5], zIndices100: zIndices[100] }}>
    a {
        background-color: var(--colorsWhite);
        left: var(--rem05);
        padding: var(--rem05);
        position: absolute;
        top: var(--rem05);
        z-index: var(--zIndices100);
    }

    a:not(:focus):not(:focus-within) {
        border: 0px;
        clip: rect(0px, 0px, 0px, 0px);
        height: 1px;
        width: 1px;
        overflow: hidden;
        padding: 0px;
        white-space: nowrap;
    }
</style>
<a href="#main" set:html={labels.main} />
<a href="#footer" set:html={labels.footer} />
