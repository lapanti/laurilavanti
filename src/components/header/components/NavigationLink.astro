---
import type { Lang } from '../../../content/nav'

import { colors, fontSizes, sizes, typographics } from '../../../lib/styles'

interface Props {
    href: string
    label: string
    switchToLang?: Lang
    title: string
}

const { href, label, switchToLang, title } = Astro.props
const { pathname } = Astro.url
---

<style
    define:vars={{
        bodyFontFamily: typographics.body.fontFamily,
        bodyFontSize: fontSizes[1.5].fontSize,
        bodyFontWeight: typographics.body.fontWeight,
        bodyLineHeight: fontSizes[1.5].lineHeight,
        colorsPeach: colors.peach,
        sizes01875: sizes[0.1875],
    }}
>
    a {
        align-items: center;
        display: flex;
        font-family: var(--bodyFontFamily);
        font-weight: var(--bodyFontWeight);
        font-size: var(--bodyFontSize);
        line-height: var(--bodyLineHeight);
        min-height: 2.75rem;
        color: var(--colorsPeach);
        position: relative;
        overflow: hidden;
    }

    a[aria-current='page'] {
        text-decoration: underline;
        text-decoration-thickness: var(--sizes01875);
    }

    a::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: var(--sizes01875);
        transition: transform 200ms ease-in-out;
        opacity: 1;
        transform: translate3d(-100%, 0, 0);
        background-color: var(--colorsPeach);
    }

    a:hover::after,
    a:focus::after {
        transform: translate3d(0, 0, 0);
    }

    a[aria-current='page']:hover::after,
    a[aria-current='page']:focus::after {
        transform: translate3d(-100%, 0, 0);
    }
</style>
<a
    aria-current={pathname.startsWith(href) ? 'page' : 'false'}
    aria-label={title !== label ? (title.includes(label) ? title : `${label} – ${title}`) : undefined}
    data-switch-to-lang={switchToLang}
    href={href}
>
    {label}
</a>
