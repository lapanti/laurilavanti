---
import { colors, HEADER_SIZE, sizes } from '../lib/styles'
import Image from './titleBanner/Image.astro'
import Title from './titleBanner/Title.astro'

interface Props {
    alt?: string
    createdAt?: string
    heroImage?: string
    lang?: 'en' | 'fi' | 'sv'
    tags?: string[]
    title: string
}

const { alt, createdAt, heroImage, lang, tags, title } = Astro.props
---

<style
    define:vars={{
        colorsEvening: colors.evening,
        colorsWhite: colors.white,
        headerSize: HEADER_SIZE,
        sizes45: sizes[45],
    }}
>
    .container {
        background-color: var(--colorsEvening);
        grid-column: 1 / -1;
        padding-top: var(--headerSize);
    }

    .content {
        background-color: var(--colorsWhite);
    }

    @media (min-width: 1200px) {
        .container {
            height: var(--sizes45);
        }

        .content {
            display: flex;
            flex-direction: row;
            height: 100%;
            justify-content: flex-end;
            margin: auto;
        }
    }
</style>
<div class="container">
    <div class="content">
        <Title createdAt={createdAt} lang={lang} tags={tags} title={title} />
        <Image alt={alt} heroImage={heroImage} />
    </div>
</div>
