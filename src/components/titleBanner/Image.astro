---
import { getImageSrcset } from '../../lib/images'

interface Props {
    alt?: string
    heroImage?: string
}

const { alt, heroImage } = Astro.props
const img = heroImage ? getImageSrcset(heroImage, 'hero', [864, 1728]) : undefined
---

<style>
    .image-container {
        display: flex;
        overflow: hidden;
        position: relative;
    }

    .image-container :global(img) {
        aspect-ratio: 864 / 660;
        height: auto;
        max-height: min(100vw, 35rem);
        object-fit: cover;
        width: 100%;
    }

    @media (min-width: 1200px) {
        .image-container {
            height: 100%;
            width: 50%;
        }

        .image-container :global(img) {
            aspect-ratio: auto;
            height: 100%;
            max-height: none;
            object-fit: cover;
            width: 100%;
        }
    }
</style>
<div class="image-container">
    {
        img && (
            <img
                alt={alt ?? ''}
                fetchpriority="high"
                height={img.height}
                sizes="(max-width: 1199px) 100vw, 50vw"
                src={img.src}
                srcset={img.srcset}
                width={img.width}
            />
        )
    }
</div>
