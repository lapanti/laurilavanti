---
import { buildTagCollection } from '../content/tags'
import ExcerptList from './ExcerptList.astro'

interface Props {
    lang?: 'en' | 'fi' | 'sv'
    limit?: number
}

const { lang = 'fi', limit } = Astro.props
const allTags = buildTagCollection(lang)
---

<ExcerptList allTags={allTags} lang={lang} limit={limit} />
