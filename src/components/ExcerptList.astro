---
import { getExcerptPosts } from '../lib/mdxPosts'
import { sizes } from '../lib/styles'
import Excerpt from './excerptList/Excerpt.astro'

interface Props {
    currentSlug?: string
    lang?: 'en' | 'fi' | 'sv'
    limit?: number
    relatedTags?: string[]
    tag?: string
}

const { currentSlug, lang = 'fi', limit, relatedTags, tag } = Astro.props

const nodes = getExcerptPosts({ currentSlug, lang, limit, relatedTags, tag })
---

<style
    define:vars={{
        sizes1: sizes[1],
        sizes2point5: sizes[2.5],
        sizes3point5: sizes[3.5],
        sizes4: sizes[4],
        sizes35: sizes[35],
    }}
>
    ul {
        column-gap: var(--sizes4);
        display: grid;
        grid-column-start: 3;
        grid-template-columns: minmax(100%, var(--sizes35));
        grid-template-rows: auto;
        justify-content: center;
        justify-items: center;
        margin-top: var(--sizes1);
        row-gap: var(--sizes3point5);
    }

    @media (min-width: 1200px) {
        ul {
            grid-template-columns: repeat(2, var(--sizes35));
            margin-top: var(--sizes2point5);
        }
    }
</style>
<ul>
    {
        nodes.map((node) => (
            <Excerpt
                alt={node.alt}
                date={node.publishDate}
                excerpt={node.description}
                image={node.heroImage}
                lang={lang}
                slug={node.url.replace(/^\//, '').replace(/\/$/, '')}
                tags={node.tags}
                title={node.title}
            />
        ))
    }
</ul>
