---
import type { TagCollection, TagLink } from 'contentful'
import type { Post } from '../types/contentful'

import { contentfulClient } from '../lib/contentful'
import { allMdxPosts } from '../lib/mdxPosts'
import { sizes } from '../lib/styles'
import Excerpt from './excerptList/Excerpt.astro'

interface Props {
    allTags: TagCollection
    currentSlug?: string
    lang?: 'en' | 'fi' | 'sv'
    limit?: number
    relatedTags?: { sys: TagLink }[]
    tag?: string
}

const { allTags, currentSlug, lang = 'fi', limit, relatedTags, tag } = Astro.props

const entries = await contentfulClient.getEntries<Post>({
    content_type: 'post',
    'fields.slug[ne]': currentSlug,
    include: 1,
    'metadata.tags.sys.id[in]': tag ? [tag] : undefined,
    /* @ts-expect-error Contentful hasn't typed this properly */
    order: '-sys.createdAt',
})

interface NormalisedPost {
    date: string
    excerpt?: string
    image?: Post['fields']['image']
    lang: 'en' | 'fi' | 'sv'
    localAlt?: string
    localImage?: string
    slug: string
    tags: { sys: TagLink }[]
    title: string
}

const contentfulNormalised: NormalisedPost[] = entries.items.map((node) => ({
    date: node.fields.publishDate || node.sys.createdAt,
    excerpt: node.fields.excerpt,
    image: node.fields.croppedImage || node.fields.image,
    lang: 'fi',
    slug: `blogi/${node.fields.slug}`,
    tags: node.metadata.tags,
    title: node.fields.title,
}))

const mdxNormalised: NormalisedPost[] = allMdxPosts
    .filter((p) => !currentSlug || p.slug !== currentSlug)
    .filter((p) => !tag || p.tags.includes(tag))
    .map((p) => ({
        date: p.publishDate,
        excerpt: p.description,
        lang: p.lang,
        localAlt: p.localAlt,
        localImage: p.localCroppedHeroImage,
        /* strip leading slash for consistent de-duplication */
        slug: p.url.replace(/^\//, '').replace(/\/$/, ''),
        tags: p.tags.map((id) => ({ sys: { id, linkType: 'Tag' as const, type: 'Link' as const } })),
        title: p.title,
    }))

/* Merge, de-duplicate by slug, keep newest-first */
const contentfulSlugs = new Set(contentfulNormalised.map((p) => p.slug))
const merged: NormalisedPost[] = [
    ...contentfulNormalised,
    ...mdxNormalised.filter((p) => !contentfulSlugs.has(p.slug)),
].sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf())

const tagSorted = relatedTags
    ? merged
          .reduce<[NormalisedPost, number][]>(
              (acc, curr) => [
                  ...acc,
                  [
                      curr,
                      relatedTags.reduce(
                          (pointsAcc, currentRelatedTag) =>
                              pointsAcc +
                              (curr.tags.map((someTag) => someTag.sys.id).includes(currentRelatedTag.sys.id) ? 1 : 0),
                          0
                      ),
                  ],
              ],
              []
          )
          .toSorted((a, b) => {
              if (a[1] === b[1]) {
                  return new Date(b[0].date).valueOf() - new Date(a[0].date).valueOf()
              }

              return a[1] < b[1] ? 1 : -1
          })
          .map((postWithPoints) => postWithPoints[0])
    : merged

const nodes = limit ? tagSorted.slice(0, limit) : tagSorted
---

<style define:vars={{ sizes2: sizes[2], sizes3point5: sizes[3.5], sizes4: sizes[4], sizes35: sizes[35] }}>
    ul {
        column-gap: var(--sizes4);
        display: grid;
        grid-column-start: 3;
        grid-template-columns: minmax(100%, var(--sizes35));
        grid-template-rows: auto;
        justify-content: center;
        justify-items: center;
        margin-top: var(--sizes2);
        row-gap: var(--sizes3point5);
    }

    @media (min-width: 1200px) {
        ul {
            grid-template-columns: repeat(2, var(--sizes35));
            margin-top: var(--sizes3point5);
        }
    }
</style>
<ul>
    {
        nodes.map((node) => (
            <Excerpt
                allTags={allTags}
                date={node.date}
                excerpt={node.excerpt}
                image={node.image}
                lang={lang}
                localAlt={node.localAlt}
                localImage={node.localImage}
                slug={node.slug}
                tags={node.tags}
                title={node.title}
            />
        ))
    }
</ul>
