---
import { allMdxPosts } from '../lib/mdxPosts'
import { sizes } from '../lib/styles'
import Excerpt from './excerptList/Excerpt.astro'

interface Props {
    currentSlug?: string
    lang?: 'en' | 'fi' | 'sv'
    limit?: number
    relatedTags?: string[]
    tag?: string
}

const { currentSlug, lang = 'fi', limit, relatedTags, tag } = Astro.props

const filtered = allMdxPosts
    .filter((p) => p.lang === lang)
    .filter((p) => !currentSlug || p.slug !== currentSlug)
    .filter((p) => !tag || p.tags.includes(tag))

type MdxPostWithUrl = (typeof filtered)[number]

const tagSorted = relatedTags
    ? filtered
          .reduce<[MdxPostWithUrl, number][]>(
              (acc, curr) => [
                  ...acc,
                  [
                      curr,
                      relatedTags.reduce(
                          (pointsAcc, currentRelatedTag) => pointsAcc + (curr.tags.includes(currentRelatedTag) ? 1 : 0),
                          0
                      ),
                  ],
              ],
              []
          )
          .toSorted((a, b) => {
              if (a[1] === b[1]) {
                  return new Date(b[0].publishDate).valueOf() - new Date(a[0].publishDate).valueOf()
              }

              return a[1] < b[1] ? 1 : -1
          })
          .map((postWithPoints) => postWithPoints[0])
    : filtered

const nodes = limit ? tagSorted.slice(0, limit) : tagSorted
---

<style define:vars={{ sizes2: sizes[2], sizes3point5: sizes[3.5], sizes4: sizes[4], sizes35: sizes[35] }}>
    ul {
        column-gap: var(--sizes4);
        display: grid;
        grid-column-start: 3;
        grid-template-columns: minmax(100%, var(--sizes35));
        grid-template-rows: auto;
        justify-content: center;
        justify-items: center;
        margin-top: var(--sizes2);
        row-gap: var(--sizes3point5);
    }

    @media (min-width: 1200px) {
        ul {
            grid-template-columns: repeat(2, var(--sizes35));
            margin-top: var(--sizes3point5);
        }
    }
</style>
<ul>
    {
        nodes.map((node) => (
            <Excerpt
                alt={node.alt}
                date={node.publishDate}
                excerpt={node.description}
                image={node.heroImage}
                lang={lang}
                slug={node.url.replace(/^\//, '').replace(/\/$/, '')}
                tags={node.tags}
                title={node.title}
            />
        ))
    }
</ul>
