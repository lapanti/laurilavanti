---
/* eslint-disable astro/no-unused-css-selector */
import { Icon } from 'astro-icon/components'

import { colors, sizes } from '../../lib/styles'

interface Props {
    ariaLabel: string
    icon?: string
    title: string
    url: string
}

const { ariaLabel, icon, title, url } = Astro.props

const iconToHoverColor = (icon?: string): string | undefined => {
    if (icon === 'fa7-brands:bluesky') {
        return colors.bluesky
    }
    if (icon === 'fa7-brands:facebook') {
        return colors.facebook
    }
    if (icon === 'fa7-brands:linkedin') {
        return colors.linkedin
    }
    if (icon === 'fa7-brands:mastodon') {
        return colors.mastodon
    }
    if (icon === 'fa7-brands:threads') {
        return colors.threads
    }
    if (icon === 'fa7-brands:tiktok') {
        return undefined
    }
    if (icon === 'fa7-solid:rss') {
        return colors.rss
    }
}

const hoverColor = iconToHoverColor(icon)
---

<style
    define:vars={{
        colorsGray: colors.gray,
        hoverColor,
        sizes0: sizes[0],
        sizes225: sizes[2.25],
    }}
>
    li {
        padding: var(--sizes0);
    }

    li a {
        align-items: center;
        display: flex;
        height: 100%;
        justify-content: center;
        min-height: 2.75rem;
        min-width: 2.75rem;
    }

    li svg {
        color: var(--colorsGray);
        height: var(--sizes225);
        width: var(--sizes225);
        stroke: currentColor;
        fill: currentColor;
    }

    li svg:hover,
    li svg:focus {
        color: var(--hoverColor);
    }
</style>
<li>
    <a aria-label={ariaLabel} href={url} rel="me noopener noreferrer" target="_blank" title={title}>
        {icon && <Icon name={icon} />}
    </a>
</li>
