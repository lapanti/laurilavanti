---
import { colors, HEADER_SIZE, sizes } from '../lib/styles'
import Images from './heroBanner/Images.astro'
import Titles from './heroBanner/Titles.astro'

interface Props {
    alt?: string
    backgroundImage?: string
    heroImage?: string
    secondaryTitle?: string
    subtitle?: string
    title: string
}

const { alt, backgroundImage, heroImage, secondaryTitle, subtitle, title } = Astro.props
---

<style
    define:vars={{
        colorsEvening: colors.evening,
        headerSize: HEADER_SIZE,
        sizes45: sizes[45],
    }}
>
    div {
        align-items: stretch;
        background: var(--colorsEvening);
        display: flex;
        flex-direction: column;
        grid-column: 1 / -1;
    }

    @media (min-width: 1200px) {
        div {
            flex-direction: row-reverse;
            height: var(--sizes45);
            padding-top: var(--headerSize);
        }
    }
</style>
<div>
    <Titles secondaryTitle={secondaryTitle} subtitle={subtitle} title={title} />
    <Images alt={alt} backgroundImage={backgroundImage} heroImage={heroImage} />
</div>
