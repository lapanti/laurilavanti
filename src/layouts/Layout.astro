---
import type { ImageMetadata } from 'astro'
import type { JsonLdType } from '../lib/jsonld'
import type { TagCollection, TagLink } from '../types/local'

import Footer from '../components/Footer.astro'
import GlobalStyle from '../components/GlobalStyle.astro'
import Head from '../components/Head.astro'
import Header from '../components/Header.astro'
import HeroBanner from '../components/HeroBanner.astro'
import TitleBanner from '../components/TitleBanner.astro'
import {
    colors,
    gridAreas,
    gridTemplateColumns,
    gridTemplateColumnsArticle,
    gridTemplateRowsLayout,
    gridTemplateRowsLayoutMobile,
} from '../lib/styles'

interface Props {
    allTags?: TagCollection
    createdAt?: string
    description?: string
    heroBanner?: boolean
    lang?: string
    localAlt?: string
    localBackgroundImage?: string
    localCroppedHeroImage?: string
    localHeroImage?: string
    secondaryTitle?: string
    slug?: string
    subtitle?: string
    tags?: { sys: TagLink }[]
    title: string
    type?: JsonLdType
    updatedAt?: string
}

const {
    allTags,
    createdAt,
    description,
    heroBanner,
    lang,
    localAlt,
    localBackgroundImage,
    localCroppedHeroImage,
    localHeroImage,
    secondaryTitle,
    slug,
    subtitle,
    tags,
    title,
    type,
    updatedAt,
} = Astro.props

const allLocalImages = import.meta.glob<ImageMetadata>('../images/**/*.{jpg,JPG,jpeg,png}', {
    eager: true,
    import: 'default',
})
const localOgImage = localCroppedHeroImage
    ? allLocalImages[`../images/${localCroppedHeroImage}`]
    : localHeroImage
      ? allLocalImages[`../images/${localHeroImage}`]
      : null
---

<html lang={lang ?? 'fi'}>
    <head>
        <GlobalStyle />
        <Head
            createdAt={createdAt}
            description={description}
            localOgImage={localOgImage ?? undefined}
            localOgImageAlt={localAlt}
            slug={slug}
            title={title}
            type={type}
            updatedAt={updatedAt}
        />
    </head>
    <body>
        <style
            define:vars={{
                colorsWhite: colors.white,
                gridAreasMain: gridAreas.main,
                gridTemplateColumns,
                gridTemplateColumnsArticle,
                gridTemplateRowsLayout,
                gridTemplateRowsLayoutMobile,
            }}
        >
            body > div {
                display: grid;
                grid-template-areas:
                    'main'
                    'footer';
                grid-template-columns: var(--gridTemplateColumns);
                grid-template-rows: var(--gridTemplateRowsLayoutMobile);
                min-height: 100dvh;
                position: relative;
            }

            main {
                background-color: var(--colorsWhite);
                grid-area: var(--gridAreasMain);
            }

            main > article {
                display: grid;
                grid-template-columns: var(--gridTemplateColumnsArticle);
            }

            @media (min-width: 1200px) {
                body > div {
                    grid-template-rows: var(--gridTemplateRowsLayout);
                }
            }
        </style>
        <div>
            <Header lang={lang as 'en' | 'fi' | 'sv' | undefined} />
            <main id="main">
                <article>
                    {
                        heroBanner ? (
                            <HeroBanner
                                localAlt={localAlt}
                                localBackgroundImage={localBackgroundImage}
                                localCroppedHeroImage={localCroppedHeroImage}
                                localHeroImage={localHeroImage}
                                secondaryTitle={secondaryTitle}
                                subtitle={subtitle}
                                title={title}
                            />
                        ) : (
                            <TitleBanner
                                allTags={allTags}
                                createdAt={createdAt}
                                localAlt={localAlt}
                                localCroppedHeroImage={localCroppedHeroImage}
                                localHeroImage={localHeroImage}
                                tags={tags}
                                title={title}
                            />
                        )
                    }
                    <slot />
                </article>
            </main>
            <Footer lang={lang as 'en' | 'fi' | 'sv' | undefined} />
        </div>
        <!-- 100% privacy-first analytics -->
        <script src="https://scripts.simpleanalyticscdn.com/latest.js" type="text/partytown"></script>
    </body>
</html>
