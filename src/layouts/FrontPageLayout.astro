---
import type { MDXLayoutProps } from 'astro'
import type { JsonLdType } from '../lib/jsonld'

import { getCldImageUrl } from 'astro-cloudinary/helpers' // eslint-disable-line import/namespace

import HeroBanner from '../components/HeroBanner.astro'
import BaseLayout from './BaseLayout.astro'

type Props = MDXLayoutProps<{
    alt?: string
    backgroundImage?: string
    description?: string
    faq?: Array<{ a: string; q: string }>
    heroImage?: string
    heroTitle?: string
    lang?: 'en' | 'fi' | 'sv'
    secondaryTitle?: string
    slug?: string
    subtitle?: string
    title: string
    type?: JsonLdType
}>

const { frontmatter } = Astro.props
const {
    alt,
    backgroundImage,
    description,
    faq,
    heroImage,
    heroTitle,
    lang,
    secondaryTitle,
    slug,
    subtitle,
    title,
    type,
} = frontmatter

const ogImage = heroImage
    ? getCldImageUrl({ crop: { source: true, type: 'fill' }, height: 630, src: heroImage, width: 1200 })
    : undefined
---

<BaseLayout
    description={description}
    faq={faq}
    lang={lang}
    ogImage={ogImage}
    ogImageAlt={alt}
    slug={slug}
    title={title}
    type={type}
>
    <HeroBanner
        alt={alt}
        backgroundImage={backgroundImage}
        heroImage={heroImage}
        secondaryTitle={secondaryTitle}
        subtitle={subtitle}
        title={heroTitle ?? title}
    />
    <slot />
</BaseLayout>
