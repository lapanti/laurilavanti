---
import type { MDXLayoutProps } from 'astro'
import type { JsonLdType } from '../lib/jsonld'

import HeroBanner from '../components/HeroBanner.astro'
import { getImage } from '../lib/images'
import BaseLayout from './BaseLayout.astro'

type Props = MDXLayoutProps<{
    alt?: string
    backgroundImage?: string
    description?: string
    faq?: Array<{ a: string; q: string }>
    heroImage?: string
    lang?: 'en' | 'fi' | 'sv'
    mobileHeroImage?: string
    pageTitle: string
    secondaryTitle?: string
    slug?: string
    subtitle?: string
    title: string
    type?: JsonLdType
}>

const { frontmatter } = Astro.props
const {
    alt,
    backgroundImage,
    description,
    faq,
    heroImage,
    lang,
    mobileHeroImage,
    pageTitle,
    secondaryTitle,
    slug,
    subtitle,
    title,
    type,
} = frontmatter

const ogImage = heroImage ? (await getImage(heroImage, 'og')).src : undefined
---

<BaseLayout
    description={description}
    faq={faq}
    lang={lang}
    ogImage={ogImage}
    ogImageAlt={alt}
    slug={slug}
    title={pageTitle}
    type={type}
>
    <HeroBanner
        alt={alt}
        backgroundImage={backgroundImage}
        heroImage={heroImage}
        mobileHeroImage={mobileHeroImage}
        secondaryTitle={secondaryTitle}
        slot="banner"
        subtitle={subtitle}
        title={title}
    />
    <slot />
</BaseLayout>
