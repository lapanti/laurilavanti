---
import type { ImageMetadata, MDXLayoutProps } from 'astro'
import type { JsonLdType } from '../lib/jsonld'

import HeroBanner from '../components/HeroBanner.astro'
import BaseLayout from './BaseLayout.astro'

type Props = MDXLayoutProps<{
    description?: string
    lang?: 'en' | 'fi' | 'sv'
    alt?: string
    backgroundImage?: string
    croppedHeroImage?: string
    heroImage?: string
    secondaryTitle?: string
    slug?: string
    subtitle?: string
    title: string
    type?: JsonLdType
}>

const { frontmatter } = Astro.props
const {
    alt,
    backgroundImage,
    croppedHeroImage,
    description,
    heroImage,
    lang,
    secondaryTitle,
    slug,
    subtitle,
    title,
    type,
} = frontmatter

const allLocalImages = import.meta.glob<ImageMetadata>('../images/**/*.{jpg,JPG,jpeg,png}', {
    eager: true,
    import: 'default',
})
const ogImage = croppedHeroImage
    ? allLocalImages[`../images/${croppedHeroImage}`]
    : heroImage
      ? allLocalImages[`../images/${heroImage}`]
      : undefined
---

<BaseLayout
    description={description}
    lang={lang}
    ogImage={ogImage}
    ogImageAlt={alt}
    slug={slug}
    title={title}
    type={type}
>
    <HeroBanner
        alt={alt}
        backgroundImage={backgroundImage}
        croppedHeroImage={croppedHeroImage}
        heroImage={heroImage}
        secondaryTitle={secondaryTitle}
        subtitle={subtitle}
        title={title}
    />
    <slot />
</BaseLayout>
