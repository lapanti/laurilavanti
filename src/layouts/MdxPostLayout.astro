---
import type { MDXLayoutProps } from 'astro'

import PostLayout from './PostLayout.astro'

type Props = MDXLayoutProps<{
    description: string
    id: number
    lang: 'en' | 'fi' | 'sv'
    localAlt: string
    localCroppedHeroImage: string
    localHeroImage: string
    publishDate: string
    slug: string
    tags: string[]
    title: string
    updatedDate?: string
}>

const { frontmatter } = Astro.props
---

<PostLayout
    description={frontmatter.description}
    id={frontmatter.id}
    lang={frontmatter.lang}
    localAlt={frontmatter.localAlt}
    localCroppedHeroImage={frontmatter.localCroppedHeroImage}
    localHeroImage={frontmatter.localHeroImage}
    publishDate={frontmatter.publishDate}
    slug={frontmatter.slug}
    tags={frontmatter.tags}
    title={frontmatter.title}
    updatedDate={frontmatter.updatedDate}
>
    <slot />
</PostLayout>
