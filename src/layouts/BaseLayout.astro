---
/* eslint-disable astro/no-unused-css-selector */
import type { JsonLdType } from '../lib/jsonld'

import FaqSection from '../components/FaqSection.astro'
import Footer from '../components/Footer.astro'
import GlobalStyle from '../components/GlobalStyle.astro'
import Head from '../components/Head.astro'
import Header from '../components/Header.astro'
import { BLOGPOSTING } from '../lib/jsonld'
import {
    colors,
    gridAreas,
    gridTemplateColumns,
    gridTemplateColumnsArticle,
    gridTemplateRowsLayout,
    gridTemplateRowsLayoutMobile,
    sizes,
} from '../lib/styles'

interface Props {
    createdAt?: string
    description?: string
    faq?: Array<{ a: string; q: string }>
    lang?: 'en' | 'fi' | 'sv'
    langAlternates?: Record<'en' | 'fi' | 'sv', string>
    noindex?: boolean
    ogImage?: string
    ogImageAlt?: string
    slug?: string
    title: string
    type?: JsonLdType
    updatedAt?: string
}

const {
    createdAt,
    description,
    faq,
    lang,
    langAlternates,
    noindex,
    ogImage,
    ogImageAlt,
    slug,
    title,
    type,
    updatedAt,
} = Astro.props
---

<html lang={lang ?? 'fi'}>
    <head>
        <GlobalStyle />
        <Head
            createdAt={createdAt}
            description={description}
            faq={faq}
            lang={lang}
            langAlternates={langAlternates}
            noindex={noindex}
            ogImage={ogImage}
            ogImageAlt={ogImageAlt}
            slug={slug}
            title={title}
            type={type}
            updatedAt={updatedAt}
        />
    </head>
    <body>
        <style
            define:vars={{
                colorsWhite: colors.white,
                gridAreasMain: gridAreas.main,
                gridTemplateColumns,
                gridTemplateColumnsArticle,
                gridTemplateRowsLayout,
                gridTemplateRowsLayoutMobile,
                paddingBlockEnd: sizes[2],
                paddingBlockStart: sizes[1],
            }}
        >
            body > div {
                display: grid;
                grid-template-areas:
                    'main'
                    'footer';
                grid-template-columns: var(--gridTemplateColumns);
                grid-template-rows: var(--gridTemplateRowsLayoutMobile);
                min-height: 100dvh;
                position: relative;
            }

            main {
                background-color: var(--colorsWhite);
                display: grid;
                grid-area: var(--gridAreasMain);
                grid-auto-rows: auto;
                grid-template-columns: var(--gridTemplateColumnsArticle);
            }

            main > article {
                display: grid;
                grid-column: 1 / -1;
                grid-template-columns: var(--gridTemplateColumnsArticle);
                padding-block: var(--paddingBlockStart) var(--paddingBlockEnd);
            }

            main > article > *:first-child {
                margin-block-start: 0;
            }

            main > article > *:last-child {
                margin-block-end: 0;
            }

            @media (min-width: 1200px) {
                body > div {
                    grid-template-rows: var(--gridTemplateRowsLayout);
                }
            }
        </style>
        <div>
            <Header lang={lang} />
            <main id="main">
                <slot name="banner" />
                <article>
                    <slot />
                    {faq && faq.length >= 2 && type !== BLOGPOSTING && <FaqSection items={faq} lang={lang} />}
                </article>
            </main>
            <Footer lang={lang} />
        </div>
        <script is:inline set:html={'window.__langAlternates=' + JSON.stringify(langAlternates ?? null) + ';'} />
        <script
            is:inline
            set:html={`
            document.querySelectorAll('a[data-switch-to-lang]').forEach(function(a) {
                var lang = a.getAttribute('data-switch-to-lang')
                if (!lang) return
                var alt = window.__langAlternates
                if (alt && alt[lang]) { a.href = alt[lang]; return }
                a.href = window.location.pathname.replace(/^\\/(fi|sv|en)\\//, '/' + lang + '/')
            })
        `}
        />
        <!-- 100% privacy-first analytics -->
        <script src="https://scripts.simpleanalyticscdn.com/latest.js" type="text/partytown"></script>
    </body>
</html>
