---
import type { ImageMetadata, MDXLayoutProps } from 'astro'

import ExcerptList from '../components/ExcerptList.astro'
import H2 from '../components/H2.astro'
import SocialShare from '../components/SocialShare.astro'
import TitleBanner from '../components/TitleBanner.astro'
import { BLOGPOSTING } from '../lib/jsonld'
import BaseLayout from './BaseLayout.astro'

type Props = MDXLayoutProps<{
    description: string
    id: number
    lang: 'en' | 'fi' | 'sv'
    alt: string
    croppedHeroImage: string
    heroImage: string
    publishDate: string
    slug: string
    tags: string[]
    title: string
    updatedDate?: string
}>

const { frontmatter } = Astro.props
const { alt, croppedHeroImage, description, heroImage, id, lang, publishDate, slug, tags, title, updatedDate } =
    frontmatter

const canonicalSlug = `${lang}/blog/${id}/${slug}`
const shareUrl = `https://laurilavanti.fi/${canonicalSlug}/`

const i18n = {
    en: {
        otherPosts: 'Other posts',
        shareAriaLabel: (t: string) => `Share links for post ${t}`,
    },
    fi: {
        otherPosts: 'Muita kirjoituksia',
        shareAriaLabel: (t: string) => `Kirjoituksen ${t} sosiaalisen median jakolinkit`,
    },
    sv: {
        otherPosts: 'Andra inlägg',
        shareAriaLabel: (t: string) => `Delningslänkar för inlägget ${t}`,
    },
}

const t = i18n[lang]

const allLocalImages = import.meta.glob<ImageMetadata>('../images/**/*.{jpg,JPG,jpeg,png}', {
    eager: true,
    import: 'default',
})
const ogImage = allLocalImages[`../images/${croppedHeroImage}`] ?? allLocalImages[`../images/${heroImage}`]
---

<BaseLayout
    createdAt={publishDate}
    description={description}
    lang={lang}
    ogImage={ogImage}
    ogImageAlt={alt}
    slug={canonicalSlug}
    title={title}
    type={BLOGPOSTING}
    updatedAt={updatedDate ?? publishDate}
>
    <TitleBanner
        alt={alt}
        createdAt={publishDate}
        croppedHeroImage={croppedHeroImage}
        heroImage={heroImage}
        lang={lang}
        tags={tags}
        title={title}
    />
    <slot />
    <SocialShare ariaLabel={t.shareAriaLabel(title)} locale={lang} shareUrl={shareUrl} title={title} />
    <H2>{t.otherPosts}</H2>
    <ExcerptList currentSlug={slug} lang={lang} limit={4} relatedTags={tags} />
</BaseLayout>
