---
import type { MDXLayoutProps } from 'astro'

import { getCldImageUrl } from 'astro-cloudinary/helpers' // eslint-disable-line import/namespace

import ExcerptList from '../components/ExcerptList.astro'
import H2 from '../components/H2.astro'
import SocialShare from '../components/SocialShare.astro'
import TitleBanner from '../components/TitleBanner.astro'
import { BLOGPOSTING, type BreadcrumbItem } from '../lib/jsonld'
import { getPostAlternates } from '../lib/mdxPosts'
import { gridTemplateColumnsArticle, sizes } from '../lib/styles'
import BaseLayout from './BaseLayout.astro'

type Props = MDXLayoutProps<{
    description: string
    faq?: Array<{ a: string; q: string }>
    id: number
    lang: 'en' | 'fi' | 'sv'
    alt: string
    heroImage: string
    pageTitle: string
    publishDate: string
    slug: string
    tags: string[]
    title: string
    updatedDate: string
}>

const { frontmatter } = Astro.props
const { alt, description, faq, heroImage, id, lang, pageTitle, publishDate, slug, tags, title, updatedDate } =
    frontmatter

const canonicalSlug = `${lang}/blog/${id}/${slug}`
const shareUrl = `https://laurilavanti.fi/${canonicalSlug}/`
const langAlternates = getPostAlternates(id)

const i18n = {
    en: {
        otherPosts: 'Other posts',
        shareAriaLabel: (t: string) => `Share links for post ${t}`,
    },
    fi: {
        otherPosts: 'Muita kirjoituksia',
        shareAriaLabel: (t: string) => `Kirjoituksen ${t} sosiaalisen median jakolinkit`,
    },
    sv: {
        otherPosts: 'Andra inlägg',
        shareAriaLabel: (t: string) => `Delningslänkar för inlägget ${t}`,
    },
}

const t = i18n[lang]

const ogImage = heroImage
    ? getCldImageUrl({ crop: { source: true, type: 'fill' }, height: 630, src: heroImage, width: 1200 })
    : undefined

const siteOrigin = 'https://laurilavanti.fi'
const homeLabel: Record<string, string> = { en: 'Home', fi: 'Etusivu', sv: 'Hem' }
const blogLabel: Record<string, string> = { en: 'Blog', fi: 'Blogi', sv: 'Blogg' }
const breadcrumbs: BreadcrumbItem[] = [
    { name: homeLabel[lang], url: `${siteOrigin}/${lang}/` },
    { name: blogLabel[lang], url: `${siteOrigin}/${lang}/blog/` },
    { name: pageTitle, url: `${siteOrigin}/${canonicalSlug}/` },
]
---

<style
    define:vars={{
        articleRowGap: sizes[1],
        gridTemplateColumnsArticle,
        otherPostsMarginBlockStart: sizes[2],
    }}
>
    .other-posts {
        display: grid;
        grid-column: 1 / -1;
        grid-template-columns: var(--gridTemplateColumnsArticle);
        margin-block-start: var(--otherPostsMarginBlockStart);
        row-gap: var(--articleRowGap);
    }
</style>
<BaseLayout
    breadcrumbs={breadcrumbs}
    createdAt={publishDate}
    description={description}
    faq={faq}
    lang={lang}
    langAlternates={langAlternates}
    ogImage={ogImage}
    ogImageAlt={alt}
    slug={canonicalSlug}
    title={pageTitle}
    type={BLOGPOSTING}
    updatedAt={updatedDate}
>
    <TitleBanner
        alt={alt}
        createdAt={publishDate}
        heroImage={heroImage}
        lang={lang}
        slot="banner"
        tags={tags}
        title={title}
    />
    <slot />
    <SocialShare ariaLabel={t.shareAriaLabel(pageTitle)} locale={lang} shareUrl={shareUrl} title={pageTitle} />
    <section class="other-posts">
        <H2>{t.otherPosts}</H2>
        <ExcerptList currentSlug={slug} lang={lang} limit={4} relatedTags={tags} />
    </section>
</BaseLayout>
