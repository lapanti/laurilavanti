---
import type { ImageMetadata } from 'astro'
import type { JsonLdType } from '../lib/jsonld'
import type { TagCollection } from '../types/local'

import TitleBanner from '../components/TitleBanner.astro'
import BaseLayout from './BaseLayout.astro'

interface Props {
    allTags?: TagCollection
    createdAt?: string
    description?: string
    lang?: 'en' | 'fi' | 'sv'
    localAlt?: string
    localCroppedHeroImage?: string
    localHeroImage?: string
    slug?: string
    tags?: string[]
    title: string
    type?: JsonLdType
    updatedAt?: string
}

// Support both MDX layout usage (props under frontmatter) and direct .astro component usage
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const props: Props = ((Astro.props as any).frontmatter as Props | undefined) ?? (Astro.props as Props)
const {
    allTags,
    createdAt,
    description,
    lang,
    localAlt,
    localCroppedHeroImage,
    localHeroImage,
    slug,
    tags,
    title,
    type,
    updatedAt,
} = props

const allLocalImages = import.meta.glob<ImageMetadata>('../images/**/*.{jpg,JPG,jpeg,png}', {
    eager: true,
    import: 'default',
})
const localOgImage = localCroppedHeroImage
    ? allLocalImages[`../images/${localCroppedHeroImage}`]
    : localHeroImage
      ? allLocalImages[`../images/${localHeroImage}`]
      : undefined
---

<BaseLayout
    createdAt={createdAt}
    description={description}
    lang={lang}
    localOgImage={localOgImage}
    localOgImageAlt={localAlt}
    slug={slug}
    title={title}
    type={type}
    updatedAt={updatedAt}
>
    <TitleBanner
        allTags={allTags}
        createdAt={createdAt}
        localAlt={localAlt}
        localCroppedHeroImage={localCroppedHeroImage}
        localHeroImage={localHeroImage}
        tags={tags}
        title={title}
    />
    <slot />
</BaseLayout>
