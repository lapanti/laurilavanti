---
import type { JsonLdType } from '../lib/jsonld'

import { getCldImageUrl } from 'astro-cloudinary/helpers' // eslint-disable-line import/namespace

import TitleBanner from '../components/TitleBanner.astro'
import BaseLayout from './BaseLayout.astro'

interface Props {
    alt?: string
    createdAt?: string
    description?: string
    faq?: Array<{ a: string; q: string }>
    heroImage?: string
    lang?: 'en' | 'fi' | 'sv'
    noindex?: boolean
    slug?: string
    tags?: string[]
    title: string
    type?: JsonLdType
    updatedAt?: string
}

// Support both MDX layout usage (props under frontmatter) and direct .astro component usage
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const props: Props = ((Astro.props as any).frontmatter as Props | undefined) ?? (Astro.props as Props)
const { alt, createdAt, description, faq, heroImage, lang, noindex, slug, tags, title, type, updatedAt } = props

const ogImage = heroImage
    ? getCldImageUrl({ crop: { source: true, type: 'fill' }, height: 630, src: heroImage, width: 1200 })
    : undefined
---

<BaseLayout
    createdAt={createdAt}
    description={description}
    faq={faq}
    lang={lang}
    noindex={noindex}
    ogImage={ogImage}
    ogImageAlt={alt}
    slug={slug}
    title={title}
    type={type}
    updatedAt={updatedAt}
>
    <TitleBanner
        alt={alt}
        createdAt={createdAt}
        heroImage={heroImage}
        lang={lang}
        slot="banner"
        tags={tags}
        title={title}
    />
    <slot />
</BaseLayout>
