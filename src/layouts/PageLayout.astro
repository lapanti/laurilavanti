---
import type { JsonLdType } from '../lib/jsonld'

import { getCldImageUrl } from 'astro-cloudinary/helpers' // eslint-disable-line import/namespace

import TitleBanner from '../components/TitleBanner.astro'
import BaseLayout from './BaseLayout.astro'

interface Props {
    createdAt?: string
    description?: string
    lang?: 'en' | 'fi' | 'sv'
    alt?: string
    heroImage?: string
    slug?: string
    tags?: string[]
    title: string
    type?: JsonLdType
    updatedAt?: string
}

// Support both MDX layout usage (props under frontmatter) and direct .astro component usage
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const props: Props = ((Astro.props as any).frontmatter as Props | undefined) ?? (Astro.props as Props)
const { alt, createdAt, description, heroImage, lang, slug, tags, title, type, updatedAt } = props

const ogImage = heroImage
    ? getCldImageUrl({ crop: { source: true, type: 'fill' }, height: 630, src: heroImage, width: 1200 })
    : undefined
---

<BaseLayout
    createdAt={createdAt}
    description={description}
    lang={lang}
    ogImage={ogImage}
    ogImageAlt={alt}
    slug={slug}
    title={title}
    type={type}
    updatedAt={updatedAt}
>
    <TitleBanner alt={alt} createdAt={createdAt} heroImage={heroImage} lang={lang} tags={tags} title={title} />
    <slot />
</BaseLayout>
