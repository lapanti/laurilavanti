---
import type { ImageMetadata } from 'astro'
import type { JsonLdType } from '../lib/jsonld'

import TitleBanner from '../components/TitleBanner.astro'
import BaseLayout from './BaseLayout.astro'

interface Props {
    createdAt?: string
    description?: string
    lang?: 'en' | 'fi' | 'sv'
    alt?: string
    croppedHeroImage?: string
    heroImage?: string
    slug?: string
    tags?: string[]
    title: string
    type?: JsonLdType
    updatedAt?: string
}

// Support both MDX layout usage (props under frontmatter) and direct .astro component usage
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const props: Props = ((Astro.props as any).frontmatter as Props | undefined) ?? (Astro.props as Props)
const { alt, createdAt, croppedHeroImage, description, heroImage, lang, slug, tags, title, type, updatedAt } = props

const allLocalImages = import.meta.glob<ImageMetadata>('../images/**/*.{jpg,JPG,jpeg,png}', {
    eager: true,
    import: 'default',
})
const ogImage = croppedHeroImage
    ? allLocalImages[`../images/${croppedHeroImage}`]
    : heroImage
      ? allLocalImages[`../images/${heroImage}`]
      : undefined
---

<BaseLayout
    createdAt={createdAt}
    description={description}
    lang={lang}
    ogImage={ogImage}
    ogImageAlt={alt}
    slug={slug}
    title={title}
    type={type}
    updatedAt={updatedAt}
>
    <TitleBanner
        alt={alt}
        createdAt={createdAt}
        croppedHeroImage={croppedHeroImage}
        heroImage={heroImage}
        lang={lang}
        tags={tags}
        title={title}
    />
    <slot />
</BaseLayout>
