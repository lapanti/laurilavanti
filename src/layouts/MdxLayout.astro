---
import type { MDXLayoutProps } from 'astro'
import type { JsonLdType } from '../lib/jsonld'

import FrontPageLayout from './FrontPageLayout.astro'
import PageLayout from './PageLayout.astro'

type Props = MDXLayoutProps<{
    description?: string
    heroBanner?: boolean
    lang?: 'en' | 'fi' | 'sv'
    localAlt?: string
    localBackgroundImage?: string
    localCroppedHeroImage?: string
    localHeroImage?: string
    secondaryTitle?: string
    slug?: string
    subtitle?: string
    title: string
    type?: JsonLdType
}>

const { frontmatter } = Astro.props
---

{
    frontmatter.heroBanner ? (
        <FrontPageLayout
            description={frontmatter.description}
            lang={frontmatter.lang}
            localAlt={frontmatter.localAlt}
            localBackgroundImage={frontmatter.localBackgroundImage}
            localCroppedHeroImage={frontmatter.localCroppedHeroImage}
            localHeroImage={frontmatter.localHeroImage}
            secondaryTitle={frontmatter.secondaryTitle}
            slug={frontmatter.slug}
            subtitle={frontmatter.subtitle}
            title={frontmatter.title}
            type={frontmatter.type}
        >
            <slot />
        </FrontPageLayout>
    ) : (
        <PageLayout
            description={frontmatter.description}
            lang={frontmatter.lang}
            localAlt={frontmatter.localAlt}
            localCroppedHeroImage={frontmatter.localCroppedHeroImage}
            localHeroImage={frontmatter.localHeroImage}
            slug={frontmatter.slug}
            title={frontmatter.title}
            type={frontmatter.type}
        >
            <slot />
        </PageLayout>
    )
}
