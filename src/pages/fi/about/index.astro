---
import CurriculumVitaeComponent from '../../../components/body/CurriculumVitae.astro'
import MdxParagraph from '../../../components/body/mdx/Paragraph.astro'
import SummaryBoxComponent from '../../../components/body/SummaryBox.astro'
import ExternalLink from '../../../components/ExternalLink.astro'
import H2 from '../../../components/H2.astro'
import {
    cvDegrees,
    cvDegreesTitle,
    cvFiduciaries,
    cvFiduciariesTitle,
    cvJobExperiences,
    cvJobExperiencesTitle,
    pageDescription,
    pageTitle,
    summaryBoxData,
} from '../../../content/fi-about'
import Content from '../../../content/fi-about.mdx'
import Layout from '../../../layouts/Layout.astro'
---

<Layout description={pageDescription} slug="fi/about" title={pageTitle} type="Person">
    <SummaryBoxComponent
        ariaLabel={summaryBoxData.ariaLabel}
        summaryRows={summaryBoxData.summaryRows}
        title={summaryBoxData.title}
    />
    <Content components={{ a: ExternalLink, h2: H2, p: MdxParagraph }} />
    <CurriculumVitaeComponent
        degrees={cvDegrees}
        degreesTitle={cvDegreesTitle}
        fiduciaries={cvFiduciaries}
        fiduciariesTitle={cvFiduciariesTitle}
        jobExperiences={cvJobExperiences}
        jobExperiencesTitle={cvJobExperiencesTitle}
    />
</Layout>
