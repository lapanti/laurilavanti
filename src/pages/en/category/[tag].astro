---
import type { LocalTag } from '../../../content/tags'

import ExcerptList from '../../../components/ExcerptList.astro'
import Paragraph from '../../../components/Paragraph.astro'
import { tags } from '../../../content/tags'
import PageLayout from '../../../layouts/PageLayout.astro'
import { COLLECTIONPAGE } from '../../../lib/jsonld'

export function getStaticPaths() {
    return tags.map((t) => ({ params: { tag: t.id }, props: { tag: t } }))
}

interface Props {
    tag: LocalTag
}

const { tag } = Astro.props

const heroImageFallback = 'Lauri-Lavanti-next-to-a-table'
const heroImageAltFallback =
    'Lauri Lavanti sitting on a stool leaning against a tall table. He is wearing a black blazer and a blue-and-white floral shirt. In the blazer pocket is a multicoloured pocket square. A staircase in the background.'

const faq = tag.faq?.en
const metaDescription = tag.metaDescription.en
const bodyParagraphs = tag.descriptions.en
---

<PageLayout
    alt={tag.heroImageAlt?.en ?? heroImageAltFallback}
    description={metaDescription}
    faq={faq}
    heroImage={tag.heroImage ?? heroImageFallback}
    lang="en"
    slug={`en/category/${tag.id}`}
    title={tag.pageTitle.en}
    type={COLLECTIONPAGE}
>
    {bodyParagraphs.map((p) => <Paragraph>{p}</Paragraph>)}
    <ExcerptList lang="en" tag={tag.id} />
</PageLayout>
