---
import ExcerptList from '../components/ExcerptList.astro'
import PageLayout from '../layouts/PageLayout.astro'
import { allMdxPosts } from '../lib/mdxPosts'

const pathname = Astro.url.pathname
const langMatch = pathname.match(/^\/(en|sv)\//)
const lang = langMatch ? (langMatch[1] as 'en' | 'sv') : 'fi'

const i18n = {
    en: { title: 'The page you were looking for was unfortunately not found — could it be one of these?' },
    fi: { title: 'Etsimääsi sivua ei valitettavasti löytynyt, olisiko se joku seuraavista?' },
    sv: { title: 'Sidan du letade efter hittades tyvärr inte — kan det vara någon av dessa?' },
}
const t = i18n[lang]

// Minimal lookup table: "lang/id" → canonical URL, serialised into the page for the redirect script
const postIndexJson = JSON.stringify(Object.fromEntries(allMdxPosts.map((p) => [p.lang + '/' + p.id, p.url])))
---

<script is:inline set:html={'window.__postIndex=' + postIndexJson + ';'} />
<script
    is:inline
    set:html={`
    (function () {
        var postIndex = window.__postIndex
        var match = window.location.pathname.match(/^\\/(fi|sv|en)\\/blog\\/(\\d+)\\//)
        if (match && postIndex) {
            var canonical = postIndex[match[1] + '/' + match[2]]
            if (canonical) {
                window.location.replace(canonical)
            }
        }
    })()
`}
/>

<PageLayout lang={lang} title={t.title}>
    <ExcerptList lang={lang} limit={8} />
</PageLayout>
