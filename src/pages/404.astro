---
import ExcerptList from '../components/ExcerptList.astro'
import { buildTagCollection } from '../content/tags'
import Layout from '../layouts/Layout.astro'

const allTags = buildTagCollection('fi')
---

<Layout allTags={allTags} title="Etsimääsi sivua ei valitettavasti löytynyt, olisiko se joku seuraavista?">
    <ExcerptList allTags={allTags} limit={8} />
</Layout>
