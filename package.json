{
  "name": "lauri-lavanti",
  "type": "module",
  "version": "1.0.0",
  "description": "Homepage of Lauri Lavanti",
  "author": "Lauri Lavanti",
  "keywords": [
    "astro"
  ],
  "engines": {
    "node": "24",
    "npm": "11"
  },
  "scripts": {
    "lint": "eslint src tests",
    "lint:fix": "npm run lint -- --fix",
    "check": "astro check",
    "dev": "astro dev",
    "build": "astro build",
    "validate-page-titles": "node scripts/check-overflow.mjs $(find src/pages -name '*.mdx') src/content/tags/*.ts",
    "validate-translations": "node scripts/validate-translations.mjs",
    "validate-slugs": "node scripts/validate-slugs.mjs",
    "audit:redirects": "node --experimental-strip-types scripts/checks/redirects.mjs",
    "check:freshness": "node --experimental-strip-types scripts/checks/freshness.ts $(find src/pages -name '*.mdx')",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:setup": "playwright install --with-deps",
    "test:e2e:snapshots": "playwright test --grep \"should match aria snapshot\"",
    "test:e2e:screenshots": "playwright test --grep \"should match screenshot\"",
    "test:e2e:axe": "playwright test --grep \"should pass accessibility test\"",
    "test:e2e:siteimprove": "playwright test --grep \"should pass siteimprove check\"",
    "test:e2e:horizontal-scroll": "playwright test --grep \"Horizontal scroll on mobile\"",
    "test:e2e:other": "playwright test --grep-invert \"should match aria snapshot|should match screenshot|should pass accessibility test|should pass siteimprove check|Horizontal scroll on mobile\"",
    "test:e2e:snapshots:update": "npm run test:e2e:snapshots -- --update-snapshots",
    "test:e2e:screenshots:update": "npm run test:e2e:screenshots -- --update-snapshots",
    "test:e2e:update": "npm run test:e2e:snapshots:update && npm run test:e2e:screenshots:update",
    "test:e2e": "playwright test",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "6.0.3",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "astro-icon": "1.1.5",
    "rehype-stringify": "10.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@iconify-json/fa7-brands": "1.2.4",
    "@iconify-json/fa7-solid": "1.2.5",
    "@playwright/test": "1.61.1",
    "@siteimprove/alfa-playwright": "0.84.2",
    "@siteimprove/alfa-test-utils": "0.84.2",
    "@stylistic/eslint-plugin": "5.10.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "25.9.5",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.24",
    "astro": "6.4.8",
    "eslint": "10.8.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-astro": "2.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.7.0",
    "happy-dom": "20.11.1",
    "husky": "9.1.7",
    "knip": "6.29.0",
    "lint-staged": "17.2.0",
    "prettier": "3.9.6",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
