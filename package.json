{
  "name": "lauri-lavanti",
  "type": "module",
  "version": "1.0.0",
  "description": "Homepage of Lauri Lavanti",
  "author": "Lauri Lavanti",
  "keywords": [
    "astro"
  ],
  "engines": {
    "node": "24",
    "npm": "11"
  },
  "scripts": {
    "lint": "eslint src tests",
    "lint:fix": "npm run lint -- --fix",
    "check": "astro check",
    "dev": "astro dev",
    "build": "astro build",
    "validate-page-titles": "node scripts/check-long-words.mjs src/content/tags.ts",
    "validate-titles": "node scripts/validate-titles.mjs",
    "validate-translations": "node scripts/validate-translations.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:setup": "playwright install --with-deps",
    "test:e2e:snapshots": "playwright test --grep \"should match aria snapshot\"",
    "test:e2e:screenshots": "playwright test --grep \"should match screenshot\"",
    "test:e2e:axe": "playwright test --grep \"should pass accessibility test\"",
    "test:e2e:siteimprove": "playwright test --grep \"should pass siteimprove check\"",
    "test:e2e:other": "playwright test --grep-invert \"should match aria snapshot|should match screenshot|should pass accessibility test|should pass siteimprove check\"",
    "test:e2e:snapshots:update": "npm run test:e2e:snapshots -- --update-snapshots",
    "test:e2e:screenshots:update": "npm run test:e2e:screenshots -- --update-snapshots",
    "test:e2e:update": "npm run test:e2e:snapshots:update && npm run test:e2e:screenshots:update",
    "test:e2e": "playwright test",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.3",
    "@astrojs/partytown": "2.1.6",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "astro-cloudinary": "^1.3.5",
    "astro-icon": "1.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@axe-core/playwright": "4.11.1",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@iconify-json/fa7-brands": "1.2.2",
    "@playwright/test": "1.58.2",
    "@siteimprove/alfa-playwright": "^0.81.4",
    "@siteimprove/alfa-test-utils": "^0.81.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/eslint-plugin": "1.6.13",
    "astro": "6.1.2",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-astro": "1.6.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "17.4.0",
    "happy-dom": "20.8.9",
    "husky": "9.1.7",
    "knip": "6.1.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.2"
  }
}
